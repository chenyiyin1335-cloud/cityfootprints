# 复制为 .env 并按需修改（本地开发用）

# ---------- 数据库配置：二选一 ----------
# 方式一：本地 MySQL，分字段配置
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=footprint_map

# 方式二：云数据库，直接粘贴完整连接串（若设置了 DATABASE_URL，会优先于上面 DB_* 字段）
# 例如：mysql://user:password@host:3306/dbname
# DATABASE_URL=

# 如果云数据库强制要求 TLS（例如 Aiven），把下载到的 ca.pem 路径填在这里
# DB_SSL_CA=

# ---------- JWT ----------
SECRET_KEY=change-this-to-a-random-secret-string
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ---------- 打卡距离校验（米） ----------
CHECKIN_MAX_DISTANCE_METERS=50

# ---------- 图片上传保存目录（本地/演示用，正式环境建议改为对象存储 OSS/S3） ----------
UPLOAD_DIR=uploads

# ---------- 跨域白名单 ----------
# 本地开发用 *，部署到 Render 后建议改成你的 Vercel 域名，例如：
# ALLOWED_ORIGINS=https://your-app.vercel.app
ALLOWED_ORIGINS=*

# ---------- 自动写入演示数据 ----------
# 云端部署且不方便手动运行 seed_data.py 时，设为 true 让应用启动时自动写入一次（表非空则跳过）
AUTO_SEED_DEMO_DATA=false
